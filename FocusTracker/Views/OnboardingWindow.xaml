<Window x:Class="FocusTracker.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Tracker" Height="620" Width="900"
        WindowStyle="SingleBorderWindow"
        Background="#0C0C0F"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Grid>
        <!-- Step 1: Tracking -->
        <Grid x:Name="Step1" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="620" Margin="48,0">
                <!-- Visual -->
                <Border Background="#141418" BorderBrush="#222228" BorderThickness="1"
                        CornerRadius="12" Padding="24,20" Margin="0,0,0,36" HorizontalAlignment="Center" Width="480">
                    <StackPanel>
                        <TextBlock Text="HOY" FontSize="9" FontWeight="Bold" Foreground="#44444F" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#C8FF00" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Figma" FontSize="13" Foreground="#EEEEF2"/>
                            </StackPanel>
                            <Border Grid.Column="1" Height="8" CornerRadius="4" Background="#1A2200" Margin="0,4,12,4">
                                <Border CornerRadius="4" Background="#C8FF00" HorizontalAlignment="Left" Width="200"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="2h 41m" FontSize="12" FontWeight="Bold" Foreground="#C8FF00"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#60AAFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="youtube.com" FontSize="13" Foreground="#EEEEF2"/>
                            </StackPanel>
                            <Border Grid.Column="1" Height="8" CornerRadius="4" Background="#0D1A2E" Margin="0,4,12,4">
                                <Border CornerRadius="4" Background="#60AAFF" HorizontalAlignment="Left" Width="110"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="1h 08m" FontSize="12" FontWeight="Bold" Foreground="#60AAFF"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#C8FF00" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="VS Code" FontSize="13" Foreground="#EEEEF2"/>
                            </StackPanel>
                            <Border Grid.Column="1" Height="8" CornerRadius="4" Background="#1A2200" Margin="0,4,12,4">
                                <Border CornerRadius="4" Background="#C8FF00" HorizontalAlignment="Left" Width="80"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="0h 52m" FontSize="12" FontWeight="Bold" Foreground="#C8FF00"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Text -->
                <TextBlock Text="Conocé cómo usás tu tiempo."
                           FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"
                           FontSize="32" FontWeight="800" Foreground="#EEEEF2"
                           TextAlignment="Center" Margin="0,0,0,14"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Focus Tracker mide en silencio cuánto tiempo pasás en cada app, programa o sitio web. Ya sea que estés trabajando, estudiando o jugando — vas a saber exactamente a dónde va tu tiempo."
                           FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                           FontSize="15" Foreground="#7A7A92"
                           TextAlignment="Center" TextWrapping="Wrap" LineHeight="24"/>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="1" Margin="48,0,48,36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#C8FF00" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Continuar →"
                        HorizontalAlignment="Right"
                        Click="Next_Click"
                        FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                        FontSize="14" FontWeight="SemiBold"
                        Foreground="#0C0C0F" Background="#C8FF00"
                        BorderThickness="0" Padding="28,12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#D8FF30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- Step 2: Dashboard -->
        <Grid x:Name="Step2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="620" Margin="48,0">
                <!-- Visual: time tabs mockup -->
                <Border Background="#141418" BorderBrush="#222228" BorderThickness="1"
                        CornerRadius="12" Padding="24,20" Margin="0,0,0,36" HorizontalAlignment="Center" Width="480">
                    <StackPanel>
                        <!-- Tabs -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Background="#C8FF00" CornerRadius="6" Padding="14,7" Margin="0,0,4,0">
                                <TextBlock Text="Hoy" FontSize="11" FontWeight="Bold" Foreground="#0C0C0F"/>
                            </Border>
                            <Border Background="#141418" BorderBrush="#222228" BorderThickness="1" CornerRadius="6" Padding="14,7" Margin="0,0,4,0">
                                <TextBlock Text="Semana" FontSize="11" Foreground="#7A7A92"/>
                            </Border>
                            <Border Background="#141418" BorderBrush="#222228" BorderThickness="1" CornerRadius="6" Padding="14,7" Margin="0,0,4,0">
                                <TextBlock Text="Mes" FontSize="11" Foreground="#7A7A92"/>
                            </Border>
                            <Border Background="#141418" BorderBrush="#222228" BorderThickness="1" CornerRadius="6" Padding="14,7">
                                <TextBlock Text="Personalizado" FontSize="11" Foreground="#7A7A92"/>
                            </Border>
                        </StackPanel>
                        <!-- Summary cards -->
                        <UniformGrid Columns="3" Margin="0,0,0,0">
                            <Border Background="#1A2200" BorderBrush="#4A6600" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="FIGMA" FontSize="8" Foreground="#44444F" Margin="0,0,0,4"/>
                                    <TextBlock Text="2h 41m" FontSize="18" FontWeight="Bold" Foreground="#C8FF00"
                                               FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"/>
                                    <TextBlock Text="3 sesiones" FontSize="10" Foreground="#7A7A92"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0D1A2E" BorderBrush="#2A4A88" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="YOUTUBE" FontSize="8" Foreground="#44444F" Margin="0,0,0,4"/>
                                    <TextBlock Text="1h 08m" FontSize="18" FontWeight="Bold" Foreground="#60AAFF"
                                               FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"/>
                                    <TextBlock Text="2 sesiones" FontSize="10" Foreground="#7A7A92"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1A2200" BorderBrush="#4A6600" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="VS CODE" FontSize="8" Foreground="#44444F" Margin="0,0,0,4"/>
                                    <TextBlock Text="0h 52m" FontSize="18" FontWeight="Bold" Foreground="#C8FF00"
                                               FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"/>
                                    <TextBlock Text="1 sesión" FontSize="10" Foreground="#7A7A92"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Analizá tus hábitos a lo largo del tiempo."
                           FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"
                           FontSize="32" FontWeight="800" Foreground="#EEEEF2"
                           TextAlignment="Center" Margin="0,0,0,14" TextWrapping="Wrap"/>
                <TextBlock Text="El Dashboard muestra cuánto tiempo pasaste en cada app o sitio, con filtros por día, semana, mes o cualquier rango de fechas que elijas. Las tres más usadas aparecen siempre destacadas."
                           FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                           FontSize="15" Foreground="#7A7A92"
                           TextAlignment="Center" TextWrapping="Wrap" LineHeight="24"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="48,0,48,36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#C8FF00" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Continuar →" HorizontalAlignment="Right" Click="Next_Click"
                        FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                        FontSize="14" FontWeight="SemiBold" Foreground="#0C0C0F" Background="#C8FF00"
                        BorderThickness="0" Padding="28,12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#D8FF30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- Step 3: Projects -->
        <Grid x:Name="Step3" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="620" Margin="48,0">
                <!-- Visual: project card -->
                <Border Background="#141418" BorderBrush="#222228" BorderThickness="1"
                        CornerRadius="12" Padding="24,20" Margin="0,0,0,36" HorizontalAlignment="Center" Width="480">
                    <StackPanel>
                        <TextBlock Text="MIS PROYECTOS" FontSize="8" FontWeight="Bold" Foreground="#44444F" Margin="0,0,0,14"/>
                        <!-- Project row 1 -->
                        <Border Background="#1A2200" BorderBrush="#4A6600" BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Rediseño web cliente" FontSize="14" FontWeight="Bold" Foreground="#EEEEF2"
                                               FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"/>
                                    <TextBlock Text="Figma · VS Code · youtube.com" FontSize="11" Foreground="#44444F" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#C8FF00" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                                    <TextBlock Text="▶  Comenzar" FontSize="11" FontWeight="Bold" Foreground="#0C0C0F"/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Project row 2 -->
                        <Border Background="#141418" BorderBrush="#222228" BorderThickness="1" CornerRadius="8" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Estudio programación" FontSize="14" FontWeight="Bold" Foreground="#EEEEF2"
                                               FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"/>
                                    <TextBlock Text="VS Code · Notion · github.com" FontSize="11" Foreground="#44444F" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1A2200" BorderBrush="#4A6600" BorderThickness="1" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                                    <TextBlock Text="▶  Comenzar" FontSize="11" FontWeight="SemiBold" Foreground="#C8FF00"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock Text="Organizá tu trabajo en proyectos."
                           FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"
                           FontSize="32" FontWeight="800" Foreground="#EEEEF2"
                           TextAlignment="Center" Margin="0,0,0,14" TextWrapping="Wrap"/>
                <TextBlock Text="Creá proyectos para agrupar las apps y webs de cada trabajo. Después podés ver exactamente cuánto tiempo le dedicaste a cada proyecto, por día, semana o mes. Un clic en Comenzar y arrancás a trackear."
                           FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                           FontSize="15" Foreground="#7A7A92"
                           TextAlignment="Center" TextWrapping="Wrap" LineHeight="24"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="48,0,48,36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#222228" Margin="4,0"/>
                    <Ellipse Width="8" Height="8" Fill="#C8FF00" Margin="4,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Empezar a usar Focus Tracker" HorizontalAlignment="Right" Click="Finish_Click"
                        FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                        FontSize="14" FontWeight="SemiBold" Foreground="#0C0C0F" Background="#C8FF00"
                        BorderThickness="0" Padding="28,12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#D8FF30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

    </Grid>
</Window>
