<Window x:Class="FocusTracker.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Topmost="True" ResizeMode="NoResize">
    <Border Background="#141418" BorderBrush="#222228" BorderThickness="1"
            CornerRadius="12" Padding="28,24">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="6" Opacity=".55"/>
        </Border.Effect>
        <StackPanel>
            <!-- Icon + Title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border x:Name="IconBorder" Width="36" Height="36" CornerRadius="8"
                        Background="#2A0008" Margin="0,0,12,0">
                    <TextBlock x:Name="TxtIcon" Text="⚠" FontSize="16" FontWeight="Bold"
                               Foreground="#FF4D6A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TxtTitle"
                           FontFamily="pack://application:,,,/Resources/Fonts/Fraunces-VariableFont.ttf#Fraunces"
                           FontSize="17" FontWeight="Bold" Foreground="#EEEEF2"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Message -->
            <TextBlock x:Name="TxtMessage" FontSize="13" Foreground="#7A7A92"
                       FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                       TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,24"/>
            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnCancel" Grid.Column="0" Content="Cancelar"
                        Click="BtnCancel_Click" Padding="0,11"
                        FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#7A7A92"/>
                            <Setter Property="BorderBrush" Value="#222228"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1C1C22"/>
                                                <Setter Property="Foreground" Value="#EEEEF2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnConfirm" Grid.Column="2" Content="Eliminar"
                        Click="BtnConfirm_Click" Padding="0,11"
                        FontFamily="pack://application:,,,/Resources/Fonts/DMSans-VariableFont.ttf#DM Sans"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#FF4D6A"/>
                            <Setter Property="BorderBrush" Value="#FF4D6A"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2A0008"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
